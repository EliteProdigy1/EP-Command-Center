# EP Command Center — environment template (Sprint 2: Notion)
# Copy the KEYS into the Netlify dashboard (Site configuration →
# Environment variables). NEVER commit real values. This file only
# documents the names; it holds no secrets.

# Notion integration token (starts with "secret_" or "ntn_")
NOTION_API_KEY=

# Notion database IDs (the 32-char id from each database's URL)
NOTION_DATABASE_PROSPECTS=
NOTION_DATABASE_PROJECTS=
NOTION_DATABASE_TASKS=
NOTION_DATABASE_AI=
NOTION_DATABASE_REVENUE=

# ── Phase 3 (do not connect yet) ──
FIRECRAWL_API_KEY=
APOLLO_API_KEY=
