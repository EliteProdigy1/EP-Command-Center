# EP Command Center — environment template (Sprint 2: Notion)
# Copy the KEYS into the Netlify dashboard (Site configuration →
# Environment variables). NEVER commit the API key. Database IDs are
# NOT secrets (useless without the key), so the real ones are filled in
# below for convenience — paste them straight into Netlify.

# Notion integration token (starts with "secret_" or "ntn_") — SECRET, do not commit a real value
NOTION_API_KEY=

# Notion database IDs — real EP OPERATING SYSTEM databases (dashes optional)
NOTION_DATABASE_PROSPECTS=a1ebd034103149098947dcf72498e599
NOTION_DATABASE_PROJECTS=717e4629f24148bd96d1b234e1c47d4d
NOTION_DATABASE_TASKS=f98f20317d43409896f16c03f56454cb
NOTION_DATABASE_AI_WORKFORCE=10dfccc83f7a405da69063c7dd19e611
NOTION_DATABASE_REVENUE=6bb3e211a6704d448c40eaa241c1d83a
NOTION_DATABASE_WEBSITE=03e0966fd7434c09b91aa932a9855f01

# ── Sprint 3: Firecrawl Intelligence ──
# Discovery + website audits run in MOCK/TEST mode until BOTH of these are set.
# Leaving FIRECRAWL_LIVE unset (or not "true") guarantees no live calls, no
# credits, and no mass enrichment — the dashboard uses built-in test data.
FIRECRAWL_API_KEY=
FIRECRAWL_LIVE=

# ── Phase 4: Apollo (do not connect yet) ──
APOLLO_API_KEY=
